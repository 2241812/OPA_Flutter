# Miscellaneous
*.class
*.log
*.pyc
*.swp
.DS_Store
.atom/
.buildlog/
.history
.svn/
migrate_working_dir/

# IntelliJ related
*.iml
*.ipr
*.iws
.idea/

# The .vscode folder contains launch configuration and tasks you configure in
# VS Code which you may wish to be included in version control, so this line
# is commented out by default.
#.vscode/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.packages
.pub-cache/
.pub/
build/
flutter_*.dll

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug/
/android/app/profile/
/android/app/release/

# Machine-specific local config (NEVER commit these)
/android/local.properties
/local.properties
**/local.properties

# Gradle wrapper binary (the .properties file IS committed, the jar is not)
/android/gradle/wrapper/gradle-wrapper.jar

# Key store files (signing secrets)
key.properties
**/*.jks
**/*.keystore

# OS files
Thumbs.db
nul
